{
  "expo": {
    "name": "Planning to Calendar",
    "slug": "planning-to-calendar",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jeromeveit.planningtocalendar",
      "infoPlist": {
        "NSCameraUsageDescription": "Utilis\u00e9 pour photographier votre planning.",
        "NSPhotoLibraryUsageDescription": "Utilis\u00e9 pour s\u00e9lectionner une photo de votre planning.",
        "NSCalendarsUsageDescription": "Utilis\u00e9 pour ajouter vos \u00e9v\u00e9nements dans votre calendrier.",
        "NSCalendarsFullAccessUsageDescription": "Utilis\u00e9 pour cr\u00e9er et ajouter vos \u00e9v\u00e9nements de planning dans votre calendrier.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.jeromeveit.planningtocalendar",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_CALENDAR"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Utilis\u00e9 pour s\u00e9lectionner une photo de votre planning.",
          "cameraPermission": "Utilis\u00e9 pour photographier votre planning."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Utilis\u00e9 pour ajouter vos \u00e9v\u00e9nements au calendrier."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "15e8c586-fbbd-476f-9fbc-4a1173d8dc84"
      }
    }
  }
}